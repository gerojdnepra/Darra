{
  "name": "scalpstation-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:testnet": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/start-testnet.ps1",
    "check:live-readiness": "tsx src/safety/live-readiness.check.ts",
    "check:testnet-runtime": "tsx src/safety/testnet-runtime-harness.ts",
    "check:testnet-preflight": "tsx src/safety/testnet-preflight-smoke.ts",
    "check:testnet-lifecycle": "tsx src/safety/testnet-lifecycle-smoke.ts",
    "check:decision-chain-integrity": "tsx src/safety/decision-chain-integrity.check.ts",
    "check:preflight-persistence": "tsx src/safety/preflight-persistence.check.ts",
    "check:recovery-audit": "tsx src/safety/recovery-audit.check.ts",
    "check:binance-time-sync": "tsx src/safety/binance-time-sync.check.ts",
    "check:open-interest-polling": "tsx src/safety/open-interest-polling.check.ts",
    "check:release-smoke": "tsx src/safety/release-smoke.check.ts",
    "check:boundaries": "tsx src/safety/boundaries.check.ts",
    "check:testnet-lifecycle:cleanup": "tsx src/safety/testnet-lifecycle-cleanup.ts",
    "check:order-safety": "tsx src/safety/order-safety.check.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "firebase-admin": "^13.6.0",
    "jsonwebtoken": "^9.0.2",
    "jwk-to-pem": "^2.0.7",
    "node-edge-tts": "^1.2.10",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jwk-to-pem": "^2.0.3",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
