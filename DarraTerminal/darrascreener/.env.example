BINANCE_REST_BASE=https://fapi.binance.com
BINANCE_WS_BASE=wss://fstream.binance.com
BACKEND_PORT=3001
BACKEND_WS_PATH=/ws
DEFAULT_FOCUS_UNIVERSE_SIZE=40
FRAME_INTERVAL_MS=1000
FOCUS_REBALANCE_INTERVAL_MS=15000
BINANCE_API_KEY=
BINANCE_API_SECRET=
AUTO_JOURNAL_FROM_BINANCE=true
POSITION_SIZING_DEFAULT_EQUITY_USDT=1000
# Leave empty to use backend/.data locally or desktop userData in the packaged app.
SCALPSTATION_SQLITE_PATH=
# Keep false unless you intentionally want LAN/remote clients to inherit the server-side .env Binance account.
ALLOW_REMOTE_ENV_BINANCE_ACCOUNT_ACCESS=false
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:3001/ws

# Android Firebase app config from Firebase project settings.
ANDROID_FIREBASE_API_KEY=
ANDROID_FIREBASE_APP_ID=
ANDROID_FIREBASE_PROJECT_ID=
ANDROID_FIREBASE_MESSAGING_SENDER_ID=
ANDROID_FIREBASE_STORAGE_BUCKET=
# IMPORTANT: use the OAuth client with type "Web application" from Google Cloud.
# Do not paste the Android OAuth client ID here.
ANDROID_FIREBASE_WEB_CLIENT_ID=
ANDROID_FACEBOOK_APP_ID=
ANDROID_FACEBOOK_CLIENT_TOKEN=

# Public HTTPS base URL of the auth broker/backend that serves /oauth/* routes.
# This host must be reachable from the phone over Wi-Fi/Internet and valid over HTTPS in production.
# Example: https://auth.scalpstation.example
ANDROID_AUTH_BROKER_BASE_URL=

# Dev fallback for local testing. In production switch this to your claimed HTTPS App Link.
# Example production value: https://auth.scalpstation.example/auth/callback
ANDROID_AUTH_REDIRECT_URI=com.troesh.scalpstation://auth/callback
ANDROID_FIREBASE_AUTH_USE_EMULATOR=false
ANDROID_FIREBASE_AUTH_EMULATOR_HOST=10.0.2.2
ANDROID_FIREBASE_AUTH_EMULATOR_PORT=9099
SOCIAL_AUTH_BROKER_MODE=live

# Public base URL used to build provider callback URLs.
# Usually this is the same host as ANDROID_AUTH_BROKER_BASE_URL.
AUTH_PUBLIC_BASE_URL=

# Comma-separated allowlist of app redirect URIs.
# In production include the same HTTPS redirect as ANDROID_AUTH_REDIRECT_URI.
# You can keep the custom scheme here as a dev fallback.
# Example:
# AUTH_APP_ALLOWED_REDIRECT_URIS=https://auth.scalpstation.example/auth/callback,com.troesh.scalpstation://auth/callback
AUTH_APP_ALLOWED_REDIRECT_URIS=com.troesh.scalpstation://auth/callback
ANDROID_APP_PACKAGE=com.troesh.scalpstation

# Comma-separated SHA-256 fingerprints for Android App Links / assetlinks.json verification.
# Include:
# 1) local debug/upload keystore SHA-256
# 2) Google Play App Signing SHA-256 from Play Console
ANDROID_APP_SHA256_CERT_FINGERPRINTS=

# Firebase Admin config for live custom token minting.
# Fill FIREBASE_SERVICE_ACCOUNT_JSON or the FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY pair.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_AUTH_EMULATOR_HOST=

# Apple Sign In values from Apple Developer.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Paste the .p8 private key as a single line with \n escapes.
APPLE_PRIVATE_KEY=
# Optional. Leave empty to use ${AUTH_PUBLIC_BASE_URL}/oauth/apple/callback
APPLE_REDIRECT_URI=

# Telegram Login / OIDC values.
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
# Optional. Leave empty to use ${AUTH_PUBLIC_BASE_URL}/oauth/telegram/callback
TELEGRAM_REDIRECT_URI=
