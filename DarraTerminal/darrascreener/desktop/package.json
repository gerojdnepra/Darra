{
  "name": "scalpstation-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Windows desktop shell for Darra Terminal",
  "main": "main.cjs",
  "scripts": {
    "prepare:bundles": "node scripts/prepare-bundles.mjs",
    "dev": "npm run prepare:bundles && electron .",
    "package:folder": "npm run prepare:bundles && node scripts/package-folder.mjs",
    "package:dir": "npm run prepare:bundles && node scripts/package-folder.mjs",
    "package:portable": "npm run prepare:bundles && electron-builder --win portable"
  },
  "build": {
    "appId": "com.troesh.scalpstation.desktop",
    "productName": "Darra Terminal",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      ".bundle/**/*",
      "package.json"
    ],
    "asar": true,
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12"
  }
}
